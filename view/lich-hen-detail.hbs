<!-- view/lich-hen-detail.hbs -->
<link rel="stylesheet" href="/css/lichHen.css" />

<div class="breadcrumb">
  <a href="/lich-hen">Lịch trình</a>
  <span class="sep">›</span>
  <span class="current">Chi tiết lên lịch hẹn</span>
</div>

<div class="page-header">
  <h1>Chi tiết lịch hẹn</h1>
  <div class="action-row" style="margin:0;">
    <a href="/lich-hen" class="btn-cancel">✕ Hủy</a>
    <button class="btn-confirm" id="btnConfirm" disabled>✓ Xác nhận lịch hẹn</button>
  </div>
</div>

<div class="detail-layout">
  <!-- LEFT: Thông tin -->
  <div style="display:flex; flex-direction:column; gap:20px;">

    <!-- Thông tin khách hàng -->
    <div class="detail-card">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h2>Thông tin khách hàng</h2>
        <span class="badge-verified">✓ Đã xác minh</span>
      </div>

      <div class="kh-info-row">
        <div class="kh-avatar-lg">{{initials khachHang.ho_va_ten}}</div>
        <div>
          <div class="kh-name">{{khachHang.ho_va_ten}}</div>
          <div class="kh-email">{{khachHang.email}}</div>
          <div class="kh-phone">
            <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {{khachHang.sdt}}
          </div>
        </div>
      </div>

      <div class="info-row">
        <span class="info-label">Mã đăng ký</span>
        <span class="info-value">#REG-{{phieu.id_phieu}}</span>
      </div>
      <div class="info-row">
        <span class="info-label">Ngày mong muốn</span>
        <span class="info-value">{{formatDate phieu.ngay_dang_ky}}</span>
      </div>
      <div class="info-row">
        <span class="info-label">Trạng thái</span>
        <span class="badge-cho">Chờ lên lịch</span>
      </div>
    </div>

    <!-- Phòng đã chọn -->
    <div class="detail-card">
      <h2>Phòng đã chọn</h2>

      {{#if phongGhep.length}}
      <div class="section-heading">Ở ghép</div>
      {{#each phongGhep}}
      <div class="phong-item">
        <div>
          <div class="phong-name">{{this.loai_phong}} - Tầng {{this.tang}}</div>
          <div class="phong-sub">ID Phòng: {{this.id_phong}}</div>
          <div class="phong-tags">
            {{#if (eq this.trang_thai "available")}}<span class="tag tag-available">Trống</span>{{/if}}
            {{#if (eq this.trang_thai "occupied")}}<span class="tag tag-occupied">Đang ở</span>{{/if}}
            {{#if (eq this.trang_thai "maintenance")}}<span class="tag tag-maintenance">Bảo trì</span>{{/if}}
            <span class="tag tag-info">Ở ghép</span>
          </div>
        </div>
        <div class="phong-price">{{formatCurrency this.gia_thue}}<span style="font-size:12px;font-weight:400;color:#6b7280;">/mo</span></div>
      </div>
      {{/each}}
      {{/if}}

      {{#if phongNguyenCan.length}}
      <div class="section-heading">Nguyên căn</div>
      {{#each phongNguyenCan}}
      <div class="phong-item">
        <div>
          <div class="phong-name">{{this.loai_phong}} - Tầng {{this.tang}}</div>
          <div class="phong-sub">ID Phòng: {{this.id_phong}}</div>
          <div class="phong-tags">
            {{#if (eq this.trang_thai "available")}}<span class="tag tag-available">Trống</span>{{/if}}
            {{#if (eq this.trang_thai "occupied")}}<span class="tag tag-occupied">Đang ở</span>{{/if}}
            {{#if (eq this.trang_thai "maintenance")}}<span class="tag tag-maintenance">Bảo trì</span>{{/if}}
            <span class="tag tag-info">Nguyên căn</span>
          </div>
        </div>
        <div class="phong-price">{{formatCurrency this.gia_thue}}<span style="font-size:12px;font-weight:400;color:#6b7280;">/mo</span></div>
      </div>
      {{/each}}
      {{/if}}

      {{#unless phongGhep.length}}{{#unless phongNguyenCan.length}}
      <p style="color:#9ca3af; font-size:14px; text-align:center; padding:20px 0;">Không có phòng nào được chọn.</p>
      {{/unless}}{{/unless}}
    </div>
  </div>

  <!-- RIGHT: Lịch trình -->
  <div class="schedule-panel">
    <div class="schedule-header">
      <h2>Lịch trình nhân viên</h2>
    </div>

    <!-- Date picker -->
    <div class="date-picker-row">
      <input type="date" id="selectedDate" min="{{today}}" />
      <button class="btn-load-schedule" id="btnLoadSchedule">Xem lịch</button>
    </div>

    <div class="legend">
      <div class="legend-item"><div class="legend-dot ld-selecting"></div>Đang chọn</div>
      <div class="legend-item"><div class="legend-dot ld-booked"></div>Đã bận</div>
      <div class="legend-item"><div class="legend-dot ld-free"></div>Trống</div>
    </div>

    <div id="scheduleGrid">
      <p style="color:#9ca3af; font-size:14px; text-align:center; padding:30px 0;">
        Chọn ngày để xem lịch trình.
      </p>
    </div>

    <!-- Ghi chú -->
    <div class="note-box" style="margin-top:20px;">
      <div class="note-box-header">
        <svg width="16" height="16" fill="none" stroke="#1e3a5f" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 20a8 8 0 100-16 8 8 0 000 16z"/></svg>
        Ghi chú lịch hẹn
      </div>
      <textarea id="ghiChu" placeholder="Thêm hướng dẫn cụ thể cho chuyến tham quan phòng hoặc sở thích của khách hàng..."></textarea>
    </div>

    <div class="checkbox-row">
      <label class="checkbox-label">
        <input type="checkbox" id="chkEmail" checked /> Gửi email xác nhận cho khách hàng
      </label>
      <label class="checkbox-label">
        <input type="checkbox" id="chkCalendar" /> Thêm vào lịch của tôi
      </label>
    </div>
  </div>
</div>

<!-- Toast notification -->
<div class="toast" id="toast"></div>

<script>
  const ID_PHIEU = {{idPhieu}};
  const ID_NHAN_SU = 1; // Replace with session user id
  
  // Time slots: 7h–17h, mỗi ca 2 tiếng
  const TIME_SLOTS = [
    { label: '07:00 AM', value: '07:00', period: 'morning' },
    { label: '09:00 AM', value: '09:00', period: 'morning' },
    { label: '11:00 AM', value: '11:00', period: 'morning' },
    { label: '01:00 PM', value: '13:00', period: 'afternoon' },
    { label: '03:00 PM', value: '15:00', period: 'afternoon' },
    { label: '05:00 PM', value: '17:00', period: 'afternoon' },
  ];

  let selectedTime = null;
  let selectedDate = null;
  const grid = document.getElementById('scheduleGrid');
  const btnConfirm = document.getElementById('btnConfirm');

  // Load schedule for selected date
  document.getElementById('btnLoadSchedule').addEventListener('click', async () => {
    const dateInput = document.getElementById('selectedDate');
    if (!dateInput.value) { showToast('Vui lòng chọn ngày', 'error'); return; }
    selectedDate = dateInput.value;
    selectedTime = null;
    btnConfirm.disabled = true;
    await renderSchedule(selectedDate);
  });

  async function renderSchedule(ngay) {
    grid.innerHTML = '<p style="color:#9ca3af;text-align:center;padding:20px;">Đang tải...</p>';
    try {
      const res = await fetch(`/lich-hen/api/ca-da-dat?ngay=${ngay}`);
      const json = await res.json();
      const booked = (json.data || []).map(d => d.gio_hen.substring(0,5));
      buildGrid(booked);
    } catch (e) {
      grid.innerHTML = '<p style="color:#ef4444;text-align:center;padding:20px;">Lỗi tải lịch.</p>';
    }
  }

  function buildGrid(bookedTimes) {
    const morning = TIME_SLOTS.filter(s => s.period === 'morning');
    const afternoon = TIME_SLOTS.filter(s => s.period === 'afternoon');

    grid.innerHTML = `
      <div class="time-section-label">Buổi sáng</div>
      <div class="time-grid">${morning.map(s => slotHTML(s, bookedTimes)).join('')}</div>
      <div class="time-section-label">Buổi chiều</div>
      <div class="time-grid">${afternoon.map(s => slotHTML(s, bookedTimes)).join('')}</div>
    `;

    grid.querySelectorAll('.btn-time:not(.booked)').forEach(btn => {
      btn.addEventListener('click', () => {
        grid.querySelectorAll('.btn-time.selected').forEach(b => {
          b.classList.remove('selected');
          b.querySelector('.t-status').textContent = 'Trống';
        });
        btn.classList.add('selected');
        btn.querySelector('.t-status').textContent = 'Đang chọn';
        selectedTime = btn.dataset.value;
        btnConfirm.disabled = false;
      });
    });
  }

  function slotHTML(slot, bookedTimes) {
    const isBooked = bookedTimes.includes(slot.value);
    return `
      <button class="btn-time ${isBooked ? 'booked' : ''}" data-value="${slot.value}">
        <span class="t-hour">${slot.label}</span>
        <span class="t-status">${isBooked ? 'Đã bận' : 'Trống'}</span>
      </button>
    `;
  }

  // Confirm appointment
  btnConfirm.addEventListener('click', async () => {
    if (!selectedDate || !selectedTime) { showToast('Vui lòng chọn ngày và giờ', 'error'); return; }
    btnConfirm.disabled = true;
    btnConfirm.textContent = 'Đang xử lý...';

    try {
      const res = await fetch('/lich-hen/xac-nhan', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          idPhieuDk: ID_PHIEU,
          ngay: selectedDate,
          gio: selectedTime,
          idNhanSu: ID_NHAN_SU,
          ghiChu: document.getElementById('ghiChu').value,
        }),
      });
      const json = await res.json();
      if (json.success) {
        showToast('Lịch hẹn đã được xác nhận!', 'success');
        setTimeout(() => window.location.href = '/lich-hen', 1800);
      } else {
        throw new Error(json.error);
      }
    } catch (e) {
      showToast('Không thể tạo lịch hẹn: ' + (e.message || ''), 'error');
      btnConfirm.disabled = false;
      btnConfirm.textContent = '✓ Xác nhận lịch hẹn';
    }
  });

  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = `toast ${type} show`;
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  // Set today as default date
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('selectedDate').value = today;
</script>
