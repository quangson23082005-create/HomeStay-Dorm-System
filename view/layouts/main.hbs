<!-- view/layouts/main.hbs -->

<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} - Homestay Dorm</title>
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/auth.css" />
  <style>
    /* Reset & Base Styles */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { 
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; 
      background: #f8fafc; 
      color: #111827; 
    }

    /* ---- Header ---- */
    .main-header {
      background: #fff;
      border-bottom: 1.5px solid #e5e7eb;
      padding: 0 40px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky; top: 0; z-index: 100;
    }
    .header-left { display: flex; align-items: center; gap: 32px; }
    .header-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; }
    .header-logo-icon { font-size: 22px; width: 36px; height: 36px; background: #eff6ff; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .header-logo-text { font-size: 16px; font-weight: 800; color: #1e3a5f; }

    /* Navigation */
    .header-nav { display: flex; align-items: center; gap: 2px; }
    .nav-link {
      padding: 8px 14px;
      border-radius: 8px;
      font-size: 14px; font-weight: 500;
      color: #6b7280;
      text-decoration: none;
      transition: all .15s;
      white-space: nowrap;
    }
    .nav-link:hover { background: #f3f4f6; color: #111827; }
    .nav-link.active { background: #eff6ff; color: #1a56db; font-weight: 600; }

    /* Right Side & Badges */
    .header-right { display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
    .header-role-badge {
      font-size: 11px; font-weight: 700;
      padding: 4px 10px; border-radius: 20px;
      text-transform: uppercase; letter-spacing: .5px;
      white-space: nowrap;
    }
    .role-sale      { background: #dcfce7; color: #166534; }
    .role-ketoan    { background: #fef9c3; color: #713f12; }
    .role-quanly    { background: #ede9fe; color: #5b21b6; }
    .role-khachhang { background: #e0f2fe; color: #0c4a6e; }

    /* Avatar & Dropdown */
    .header-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: #1e3a5f;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 700; color: #fff;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
    }
    .avatar-dropdown {
      position: absolute; top: 44px; right: 0;
      background: #fff;
      border: 1.5px solid #e5e7eb;
      border-radius: 12px;
      box-shadow: 0 8px 30px rgba(0,0,0,.12);
      min-width: 190px;
      display: none;
      overflow: hidden;
      z-index: 200;
    }
    .avatar-dropdown.open { display: block; }
    .dropdown-info { padding: 14px 16px; border-bottom: 1px solid #f3f4f6; }
    .dropdown-name { font-size: 14px; font-weight: 700; color: #111827; }
    .dropdown-role { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .dropdown-logout {
      display: flex; align-items: center; gap: 8px;
      padding: 12px 16px;
      font-size: 14px; color: #ef4444; font-weight: 500;
      text-decoration: none;
      transition: background .15s;
    }
    .dropdown-logout:hover { background: #fef2f2; }

    /* ---- Main content ---- */
    .main-content { max-width: 1200px; margin: 0 auto; padding: 32px 40px; }
  </style>
</head>

<body>
  <header class="main-header">
    <div class="header-left">
      <a href="/dashboard" class="header-logo">
        <div class="header-logo-icon">🏠</div>
        <span class="header-logo-text">Homestay Dorm</span>
      </a>

      <nav class="header-nav">
        <a href="/dashboard" class="nav-link">Trang chủ</a>

        {{!-- NHÂN VIÊN SALE --}}
        {{#if (eq user.role "sale")}}
        <a href="/khach-hang" class="nav-link">Khách hàng</a>
        <a href="/lich-hen" class="nav-link">Lịch hẹn</a>
        <a href="/hop-dong" class="nav-link">Lập hợp đồng</a>
        {{/if}}

        {{!-- KẾ TOÁN --}}
        {{#if (eq user.role "ketoan")}}
        <a href="/hoan-coc" class="nav-link">Hoàn cọc</a>
        <a href="/xu-ly-khoan-thu" class="nav-link">Xử lý khoản thu</a>
        {{/if}}

        {{!-- QUẢN LÝ --}}
        {{#if (eq user.role "quanly")}}
        <a href="/lap-bien-ban" class="nav-link">Lập biên bản</a>
        <a href="/thong-ke" class="nav-link">Thống kê</a>
        <a href="/phe-duyet" class="nav-link">Phê duyệt</a>
        <a href="/quan-ly" class="nav-link">Quản lý</a>
        {{/if}}

        {{!-- KHÁCH HÀNG --}}
        {{#if (eq user.role "khachhang")}}
        <a href="/dang-ky-thue" class="nav-link">Đăng ký thuê</a>
        <a href="/so-do-phong" class="nav-link">Sơ đồ phòng</a>
        <a href="/xac-nhan-thue" class="nav-link">Xác nhận thuê phòng</a>
        <a href="/checkout-schedules" class="nav-link">Xếp lịch trả phòng</a>
        {{/if}}
      </nav>
    </div>

    <div class="header-right">
      <span class="header-role-badge role-{{user.role}}">{{user.roleLabel}}</span>

      <div class="header-avatar" id="avatarBtn">
        {{user.avatar}}
        <div class="avatar-dropdown" id="avatarDropdown">
          <div class="dropdown-info">
            <div class="dropdown-name">{{user.ho_ten}}</div>
            <div class="dropdown-role">{{user.roleLabel}}</div>
          </div>
          <a href="/logout" class="dropdown-logout">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Đăng xuất
          </a>
        </div>
      </div>
    </div>
  </header>

  <main class="main-content">
    {{{body}}}
  </main>
