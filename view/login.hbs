<!-- view/login.hbs -->
<div class="login-wrapper">
  <div class="login-card">
    <!-- Logo -->
    <div class="login-logo">
      <div class="logo-icon">🏠</div>
      <div class="logo-text">
        <span class="logo-main">Homestay</span>
        <span class="logo-sub">Dorm</span>
      </div>
    </div>

    <h1 class="login-title">Đăng nhập</h1>
    <p class="login-desc">Chào mừng bạn trở lại! Vui lòng đăng nhập để tiếp tục.</p>

    {{#if error}}
    <div class="login-error">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      {{error}}
    </div>
    {{/if}}

    <form method="POST" action="/login" class="login-form">
      <div class="form-group">
        <label>Tên đăng nhập</label>
        <input
          type="text"
          name="username"
          value="{{username}}"
          placeholder="Nhập tên đăng nhập..."
          autocomplete="username"
          required
        />
      </div>

      <div class="form-group">
        <label>Mật khẩu</label>
        <div class="input-password">
          <input
            type="password"
            name="password"
            id="passwordInput"
            placeholder="Nhập mật khẩu..."
            autocomplete="current-password"
            required
          />
          <button type="button" class="toggle-pw" id="togglePw">
            <svg id="eyeIcon" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-login">Đăng nhập</button>
    </form>

    <!-- Gợi ý tài khoản test -->
    <div class="account-hints">
      <p class="hints-title">Tài khoản test:</p>
      <div class="hints-grid">
        <div class="hint-item" onclick="fillLogin('sale','sale123')">
          <span class="hint-role sale">Sales</span>
          <span class="hint-cred">sale / sale123</span>
        </div>
        <div class="hint-item" onclick="fillLogin('ketoan','ketoan123')">
          <span class="hint-role ketoan">Kế toán</span>
          <span class="hint-cred">ketoan / ketoan123</span>
        </div>
        <div class="hint-item" onclick="fillLogin('quanly','quanly123')">
          <span class="hint-role quanly">Quản lý</span>
          <span class="hint-cred">quanly / quanly123</span>
        </div>
        <div class="hint-item" onclick="fillLogin('khachhang','kh123')">
          <span class="hint-role kh">Khách hàng</span>
          <span class="hint-cred">khachhang / kh123</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Toggle password visibility
  document.getElementById('togglePw').addEventListener('click', () => {
    const input = document.getElementById('passwordInput');
    input.type = input.type === 'password' ? 'text' : 'password';
  });

  // Fill login form from hint
  function fillLogin(username, password) {
    document.querySelector('input[name="username"]').value = username;
    document.getElementById('passwordInput').value = password;
  }
</script>
