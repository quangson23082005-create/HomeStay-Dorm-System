<div style="max-width:1120px;margin:0 auto;padding:6px 0 24px;">
  <div
    style="display:flex;align-items:center;gap:10px;margin-bottom:22px;color:#1e3a8a;font-weight:800;font-size:26px"
  >
    <span style="font-size:24px">💳</span>
    <span>Thanh toán tiền cọc</span>
  </div>

  <div
    style="display:grid;grid-template-columns:minmax(0,1.35fr) minmax(340px,.95fr);gap:16px;align-items:start"
  >
    <section style="display:grid;gap:12px">
      <div
        style="background:#fff;border:1px solid #d1d5db;border-radius:8px;padding:12px 14px 16px;box-shadow:0 1px 2px rgba(15,23,42,.03)"
      >
        <div
          style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px"
        >
          <h2
            style="font-size:16px;font-weight:700;color:#374151;margin:0"
          >Thông tin khách hàng</h2>
          <span
            style="font-size:11px;font-weight:800;color:#3563ff;background:#eff6ff;border:1px solid #dbeafe;padding:6px 10px;border-radius:999px"
          >CHỜ THANH TOÁN</span>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px">
          <div>
            <div
              style="font-size:11px;color:#6b7280;font-weight:700;margin-bottom:5px"
            >Khách hàng</div>
            <div style="font-size:14px;color:#111827">{{customerName}}</div>
          </div>
          <div>
            <div
              style="font-size:11px;color:#6b7280;font-weight:700;margin-bottom:5px"
            >SDT</div>
            <div style="font-size:14px;color:#111827">{{phieu.sdt}}</div>
          </div>
        </div>
      </div>

      <div
        style="background:#fff;border:1px solid #d1d5db;border-radius:8px;overflow:hidden;box-shadow:0 1px 2px rgba(15,23,42,.03)"
      >
        <div
          style="display:flex;justify-content:space-between;align-items:center;padding:12px 14px 10px;border-bottom:1px solid #eef2f7"
        >
          <h2 style="font-size:16px;font-weight:700;color:#374151;margin:0">Chi
            tiết khoản thanh toán</h2>
          <div style="font-size:12px;color:#6b7280">Tháng 05/2024</div>
        </div>

        <div style="padding:0 14px 14px">
          <div
            style="display:grid;grid-template-columns:1fr auto auto auto;gap:12px;align-items:center;padding:16px 0 10px;border-bottom:1px solid #eef2f7;font-size:13px;color:#6b7280;font-weight:700"
          >
            <div>Tiền đặt cọc (Deposit)</div>
            <div style="text-align:right">Đơn giá</div>
            <div style="text-align:center">Số lượng</div>
            <div style="text-align:right">Thành tiền</div>
          </div>

          <div
            style="display:grid;grid-template-columns:1fr auto auto auto;gap:12px;align-items:center;padding:16px 0 14px;border-bottom:1px solid #eef2f7;font-size:14px;color:#111827"
          >
            <div>
              <div style="font-weight:600">Tiền đặt cọc (Deposit)</div>
              <div style="font-size:12px;color:#6b7280;margin-top:3px">Hoàn trả
                khi kết thúc hợp đồng</div>
            </div>
            <div style="text-align:right">{{phieu.so_tien_coc}} VND</div>
            <div style="text-align:center">1</div>
            <div style="text-align:right">{{phieu.so_tien_coc}} VND</div>
          </div>

          <div
            style="display:flex;justify-content:space-between;align-items:flex-end;padding-top:16px"
          >
            <div style="font-size:20px;font-weight:800;color:#374151">Tổng cộng</div>
            <div
              style="text-align:right;font-size:24px;font-weight:900;color:#1d4ed8;line-height:1"
            >{{phieu.so_tien_coc}}<div
                style="font-size:14px;font-weight:800;color:#1d4ed8;margin-top:4px"
              >VND</div></div>
          </div>
        </div>
      </div>

      <div style="display:flex;justify-content:flex-start">
        <a
          href="/phieu-dat-coc/{{phieu.ma_phieu}}"
          style="display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border:1px solid #9ca3af;border-radius:2px;background:#fff;color:#374151;text-decoration:none;font-size:13px"
        >← Quay lại</a>
      </div>
    </section>

    <aside style="display:grid;gap:16px">
      <div
        style="background:#fff;border:1px solid #d1d5db;border-radius:8px;overflow:hidden;box-shadow:0 1px 2px rgba(15,23,42,.03)"
      >
        <div
          style="padding:12px 14px 10px;border-bottom:1px solid #eef2f7;font-size:16px;color:#374151"
        >Phương thức thanh toán</div>

        <div style="padding:14px 14px 16px">
          <div
            style="border:2px solid #214dd7;border-radius:6px;padding:12px 14px;display:flex;align-items:center;justify-content:space-between;gap:16px;background:#f8fbff"
          >
            <div style="display:flex;align-items:center;gap:12px">
              <div
                style="width:34px;height:34px;border-radius:8px;background:#eff6ff;display:flex;align-items:center;justify-content:center;color:#1e40af;font-size:18px"
              >🏦</div>
              <div>
                <div
                  style="font-size:15px;color:#1e40af;font-weight:600;line-height:1.15"
                >Chuyển khoản</div>
                <div style="font-size:11px;color:#6b7280;margin-top:3px">Xác
                  nhận thanh toán ngay</div>
              </div>
            </div>
            <div
              style="width:20px;height:20px;border-radius:50%;border:2px solid #214dd7;display:flex;align-items:center;justify-content:center;color:#214dd7;font-size:12px;font-weight:900"
            >✓</div>
          </div>
        </div>

        <div style="padding:0 14px 14px">
          <div
            style="background:#f8fafc;border:1px solid #e5e7eb;border-radius:6px;overflow:hidden"
          >
            <div
              style="display:grid;grid-template-columns:1fr auto;gap:12px;padding:11px 12px;border-bottom:1px solid #e5e7eb;font-size:12px;color:#6b7280"
            >
              <div>Ngân hàng</div>
              <div style="font-weight:500;color:#374151">VietinBank</div>
            </div>
            <div
              style="display:grid;grid-template-columns:1fr auto;gap:12px;padding:11px 12px;border-bottom:1px solid #e5e7eb;font-size:12px;color:#6b7280"
            >
              <div>Số tài khoản</div>
              <div
                style="display:flex;align-items:center;gap:6px;color:#374151;font-weight:500"
              >1028384950
                <span style="font-size:12px;color:#2563eb">⧉</span></div>
            </div>
            <div
              style="display:grid;grid-template-columns:1fr auto;gap:12px;padding:11px 12px;border-bottom:1px solid #e5e7eb;font-size:12px;color:#6b7280"
            >
              <div>Chủ tài khoản</div>
              <div style="font-weight:500;color:#374151">Homestay Dorm
                Management</div>
            </div>
            <div
              style="display:grid;grid-template-columns:1fr auto;gap:12px;padding:11px 12px;font-size:12px;color:#6b7280"
            >
              <div>Số tiền</div>
              <div style="font-weight:700;color:#1d4ed8">{{phieu.so_tien_coc}}
                VND</div>
            </div>
          </div>
        </div>

        <div style="padding:0 14px 14px">
          <form
            action="/phieu-dat-coc/{{phieu.ma_phieu}}/thanh-toan"
            method="post"
          >
            <button
              type="submit"
              style="width:100%;background:#0b3aa6;color:#fff;border:none;border-radius:4px;padding:12px 16px;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px"
            >🛡 Xác nhận thanh toán</button>
          </form>
        </div>
      </div>
    </aside>
  </div>
</div>